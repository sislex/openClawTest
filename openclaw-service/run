#!/usr/bin/with-contenv bash

export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
export HOME="/root"

echo "[openclaw] $(date '+%Y-%m-%d %H:%M:%S') — ожидание инициализации контейнера..."
sleep 5

# Ждём пока /app будет доступен (volume может примонтироваться с задержкой)
for i in $(seq 1 10); do
    [ -d "/app" ] && break
    echo "[openclaw] $(date '+%Y-%m-%d %H:%M:%S') — /app не готов, повтор через 2с ($i/10)..."
    sleep 2
done

OPENCLAW_DIR="/config/.openclaw"
OPENCLAW_CONFIG="$OPENCLAW_DIR/openclaw.json"

# Если конфига нет — создаём начальную конфигурацию напрямую
if [ ! -f "$OPENCLAW_CONFIG" ]; then
    echo "[openclaw] $(date '+%Y-%m-%d %H:%M:%S') — первый запуск, создание конфигурации..."
    mkdir -p "$OPENCLAW_DIR"
    cat > "$OPENCLAW_CONFIG" << 'CONF'
{
  "gateway": {
    "mode": "local"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  }
}
CONF
else
    echo "[openclaw] $(date '+%Y-%m-%d %H:%M:%S') — конфигурация найдена, обновляем..."
    openclaw config set gateway.mode local 2>/dev/null || true
    openclaw config set channels.telegram.dmPolicy open 2>/dev/null || true
    openclaw config set channels.telegram.allowFrom '["*"]' 2>/dev/null || true
fi

echo "[openclaw] $(date '+%Y-%m-%d %H:%M:%S') — запуск gateway..."
exec openclaw gateway run
