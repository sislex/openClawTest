# Модель для openclaw (например: phi3:mini, claude-sonnet-4-6)
MODEL=

# OpenClaw Gateway auth token (любая случайная строка, например: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# Anthropic / Claude API
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=

# Google / Gemini API
GEMINI_SEARCH_API_KEY=
GOOGLE_API_KEY=

# OpenAI API
OPENAI_API_KEY=


